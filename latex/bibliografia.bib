publisher = {Taylor {\&} Francis Group},
title = {{Selective reminding test: An examination of the equivalence of four forms}},
url = {https://www.tandfonline.com/doi/abs/10.1080/01688638508401258},
volume = {7},
year = {1985}
}
@article{Knudsen1986,
abstract = {Blood-brain barrier (BBB) permeability to 24Na+, 36Cl-, and [3H]sucrose was studied in rats after 2 wk of streptozocin-induced diabetes. The PS (permeability-surface area product) for Na+ in the cortex of the frontal lobes was 5.4 ± 0.6 (10-5 cm3 {\textperiodcentered} g-1 {\textperiodcentered} s-1; ± SD) in diabetic rats compared with 7.1 ± 1.7 in control rats. In the occipital cortex, the values were 7.6 ± 1.5 and 9.9 ± 1.6, respectively. In contrast, BBB permeability to Cl- and sucrose remained unchanged. We conclude that a selective alteration in BBB permeability to Na+ unrelated to changes in brain capillary surface area is present in experimental diabetes.},
author = {Knudsen, G. M. and Jakobsen, J. and Juhler, M. and Paulson, O. B.},
doi = {10.2337/diab.35.12.1371},
file = {:D$\backslash$:/Mendeley/Diabetes/1986 - Knudsen et al. - Decreased blood-brain barrier permeability to sodium in early experimental diabetes.pdf:pdf},
issn = {00121797},
journal = {Diabetes},
