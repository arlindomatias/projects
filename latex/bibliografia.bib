issn = {13624962},
journal = {Nucleic Acids Res.},
number = {D1},
pages = {D498--D503},
pmid = {31691815},
publisher = {Oxford University Press},
title = {{The reactome pathway knowledgebase}},
volume = {48},
year = {2020}
