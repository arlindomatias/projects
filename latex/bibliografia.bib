journal = {J. Pediatr.},
month = {jan},
number = {1},
pages = {131--133},
pmid = {1060745},
publisher = {Elsevier},
title = {{Reversible dementia temporally associated with intraventricular therapy with methotrexate in a child with acute myelogenous leukemia}},
url = {https://www.jpeds.com/action/showFullText?pii=S0022347676807445 https://www.jpeds.com/action/showAbstract?pii=S0022347676807445 https://www.jpeds.com/article/S0022-3476(76)80744-5/abstract},
volume = {88},
