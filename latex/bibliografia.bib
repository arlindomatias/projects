@article{Tylutka2022,
abstract = {The immunosenescence-related disproportion in T lymphocytes may have important consequences for endothelial dysfunction, which is a key event in vascular aging. The study was designed to assess the prognostic values of the inflammatory-immune profile to better predict and prevent vascular diseases associated with old age. Eighty individuals aged 70.9 ± 5.3 years were allocated to a low- (LGI) or high-grade inflammation (HGI) group based on CRP ({\textless}3 or ≥3 mg/L) as a conventional risk marker of cardiovascular diseases. Significant changes in inflammatory and endothelium-specific variables IL-1$\beta$, IL-6, TNF$\alpha$, oxLDL, H2O2, NO, 3-nitrotyrosine, and endothelial progenitor cells (OR 7.61, 95{\%} CI 2.56–29.05, p {\textless} 0.0001), confirmed their interplay in vascular inflammation. The flow-cytometry analysis demonstrated a high disproportion in T lymphocytes CD4+ and CD8+ between LGI and HGI groups. CRP was {\textless}3 mg/mL for the CD4/CD8 ratio within the reference values ≥ 1 or ≤2.5, unlike for the CD4/CD8 ratio {\textless} 1 and {\textgreater}2.5. The odds ratios for the distribution of CD4+ (OR 5.98, 95{\%} CI 0.001–0.008, p {\textless} 0.001), CD8+ (OR 0.23, 95{\%} CI 0.08–0.59, p {\textless} 0.01), and CD8CD45RO+ T na{\"{i}}ve cells (OR 0.27, 95{\%} CI 0.097–0.695, p {\textless} 0.01) and CD4/CD8 (OR 5.69, 95{\%} CI 2.07–17.32, p {\textless} 0.001) indicated a potential diagnostic value of T lymphocytes for clinical prognosis in aging-related vascular dysfunction.},
author = {Tylutka, Anna and Morawin, Barbara and Wawrzyniak-Gramacka, Edyta and Wacka, Eryk and Nowicka, Wiktoria and Hiczkiewicz, Jaroslaw and Zembron-Lacny, Agnieszka},
doi = {10.3390/ijms232113269},
file = {:D$\backslash$:/Mendeley/International Journal of Molecular Sciences/2022 - Tylutka et al. - Immunosenescence in Aging-Related Vascular Dysfunction.pdf:pdf},
issn = {14220067},
journal = {Int. J. Mol. Sci.},
keywords = {endothelial progenitor cells,flow-cytometry,immune risk profile,inflammation,oxidative stress},
number = {21},
pages = {1--16},
pmid = {36362055},
title = {{Immunosenescence in Aging-Related Vascular Dysfunction}},
volume = {23},
year = {2022}
}
@article{Chidambaram2019,
abstract = {Dendritic spines are small, thin, specialized protrusions from neuronal dendrites, primarily localized in the excitatory synapses. Sophisticated imaging techniques revealed that dendritic spines are complex structures consisting of a dense network of cytoskeletal, transmembrane and scaffolding molecules, and numerous surface receptors. Molecular signaling pathways, mainly Rho and Ras family small GTPases pathways that converge on actin cytoskeleton, regulate the spine morphology and dynamics bi-directionally during synaptic activity. During synaptic plasticity the number and shapes of dendritic spines undergo radical reorganizations. Long-term potentiation (LTP) induction promote spine head enlargement and the formation and stabilization of new spines. Long-term depression (LTD) results in their shrinkage and retraction. Reports indicate increased spine density in the pyramidal neurons of autism and Fragile X syndrome patients and reduced density in the temporal gyrus loci of schizophrenic patients. Post-mortem reports of Alzheimer's brains showed reduced spine number in the hippocampus and cortex. This review highlights the spine morphogenesis process, the activity-dependent structural plasticity and mechanisms by which synaptic activity sculpts the dendritic spines, the structural and functional changes in spines during learning and memory using LTP and LTD processes. It also discusses on spine status in neurodegenerative diseases and the impact of nootropics and neuroprotective agents on the functional restoration of dendritic spines.},
author = {Chidambaram, Saravana Babu and Rathipriya, A. G. and Bolla, Srinivasa Rao and Bhat, Abid and Ray, Bipul and Mahalakshmi, Arehally Marappa and Manivasagam, Thamilarasan and Thenmozhi, Arokiasamy Justin and Essa, Musthafa Mohamed and Guillemin, Gilles J. and Chandra, Ramesh and Sakharkar, Meena Kishore},
doi = {10.1016/j.pnpbp.2019.01.005},
file = {:D$\backslash$:/Mendeley/Progress in Neuro-Psychopharmacology and Biological Psychiatry/2019 - Chidambaram et al. - Dendritic spines Revisiting the physiological role.pdf:pdf},
issn = {18784216},
journal = {Prog. Neuro-Psychopharmacology Biol. Psychiatry},
keywords = {Dendritic spine pathology,Dendritic spines,Neurological diseases,Spine dynamics,synaptic plasticity},
number = {July 2018},
pages = {161--193},
pmid = {30654089},
title = {{Dendritic spines: Revisiting the physiological role}},
volume = {92},
year = {2019}
}
