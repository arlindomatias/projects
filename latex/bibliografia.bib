number = {3},
pages = {193--197},
publisher = {Routledge},
title = {{Empirical Considerations on Intelligence Testing and Models of Intelligence: Updates for Educational Measurement Professionals}},
url = {https://doi.org/10.1080/08957347.2019.1619564},
volume = {32},
