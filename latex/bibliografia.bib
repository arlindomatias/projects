keywords = {Cell morphology,Ex vivo,In vivo,Microglia,Quantitative imaging,Radiation},
pages = {75--92},
pmid = {36710053},
publisher = {Elsevier},
title = {{MorphoMacro for in vivo and ex vivo quantitative morphometric analysis of microglia}},
