abstract = {Among 61 cancer patients referred for neuropsychiatric consultation, 43 (71{\%}) had an organic mental disorder, and in 11 patients the disorder was consistent with dementia. Three of these cases are described in some detail to discuss the possible etiology of the organic mental disorder and to stress the importance of understanding the neurotoxic effects of chemotherapeutic agents. {\textcopyright} 2011, The Academy of Psychosomatic Medicine. All rights reserved.},
