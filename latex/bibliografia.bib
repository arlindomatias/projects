file = {:D$\backslash$:/Mendeley/Annual Review of Neuroscience/2022 - Challis et al. - Adeno-Associated Virus Toolkit to Target Diverse Brain Cells.pdf:pdf},
issn = {15454126},
journal = {Annu. Rev. Neurosci.},
keywords = {AAV,adeno-associated virus,systemic delivery,targeted brain delivery,viral capsid engineering,viral cargo},
pages = {447--469},
pmid = {35440143},
title = {{Adeno-Associated Virus Toolkit to Target Diverse Brain Cells}},
volume = {45},
year = {2022}
}
@article{Fathi2022,
abstract = {Modeling age-related neurodegenerative disorders with human stem cells are difficult due to the embryonic nature of stem cell-derived neurons. We developed a chemical cocktail to induce senescence of iPSC-derived neurons to address this challenge. We first screened small molecules that induce embryonic fibroblasts to exhibit features characteristic of aged fibroblasts. We then optimized a cocktail of small molecules that induced senescence in fibroblasts and cortical neurons without causing DNA damage. The utility of the “senescence cocktail” was validated in motor neurons derived from ALS patient iPSCs which exhibited protein aggregation and axonal degeneration substantially earlier than those without cocktail treatment. Our “senescence cocktail” will likely enhance the manifestation of disease-related phenotypes in neurons derived from iPSCs, enabling the generation of reliable drug discovery platforms.},
author = {Fathi, Ali and Mathivanan, Sakthikumar and Kong, Linghai and Petersen, Andrew J. and Harder, Cole R K. and Block, Jasper and Miller, Julia Marie and Bhattacharyya, Anita and Wang, Daifeng and Zhang, Su Chun},
doi = {10.1111/acel.13541},
file = {:D$\backslash$:/Mendeley/Aging Cell/2022 - Fathi et al. - Chemically induced senescence in human stem cell-derived neurons promotes phenotypic presentation of neurodegenera.pdf:pdf},
issn = {14749726},
journal = {Aging Cell},
keywords = {biology,department of cell and,health,public,regenerative,school of medicine and,university of wisconsin-},
number = {1},
pages = {1--21},
