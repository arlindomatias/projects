file = {:D$\backslash$:/Mendeley/Neuroscience Letters/2017 - H{\aa}kansson et al. - Semaphorin 6A knockout mice display abnormalities across ethologically-based topographies of exploration and i.pdf:pdf},
issn = {18727972},
journal = {Neurosci. Lett.},
